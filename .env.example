# UniPrint ERP & Client System — example environment variables
# Phase-0: реальные интеграции замокированы, ниже — placeholder для prod-фазы.
# НЕ коммитить .env с реальными ключами. См. CLAUDE.md § «Безопасность».
#
# Закрытые решения (2026-05-05):
#   Q6 ✅ Mobile = PWA (нет mobile-specific keys)
#   Q7 ✅ Telegram НЕ в продукте (нет TELEGRAM_BOT_TOKEN)
#   Q10 ✅ Карты = Yandex Maps
#   Q11 ✅ Хранилище = Yandex Object Storage
#   Q14 ✅ ОФД обязателен (B2C есть)
#
# Открытые блокеры:
#   Q1 юрисдикция, Q2 Face Control, Q3 хостинг,
#   Q4 миграция, Q5 эквайринг (+ конкретный ОФД-провайдер)

# ──────────────────────────────────────────────────────────
# Backend (TBD-стек, ADR-0004)
# ──────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://uniprint:uniprint@localhost:5432/uniprint
DATABASE_POOL_MAX=20

# ──────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────
# S3 (макеты) — Yandex Object Storage (Q11 ✅)
# Регион зависит от Q3 (хостинг)
# ──────────────────────────────────────────────────────────
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=uniprint-layouts

# ──────────────────────────────────────────────────────────
# Карты — Yandex Maps (Q10 ✅)
# ──────────────────────────────────────────────────────────
YANDEX_MAPS_API_KEY=

# ──────────────────────────────────────────────────────────
# Face Control — vendor TBD (🔴 Q2)
# ──────────────────────────────────────────────────────────
FACECTRL_VENDOR=mock
# FACECTRL_VENDOR=ntechlab|hikvision|suprema (после ADR-0002)
FACECTRL_API_KEY=
FACECTRL_ENDPOINT=

# ──────────────────────────────────────────────────────────
# Эквайринг — vendor TBD (🔴 Q5)
# ──────────────────────────────────────────────────────────
PAYMENTS_PROVIDER=mock
# PAYMENTS_PROVIDER=yookassa|tinkoff|sber (после ADR-0005)
PAYMENTS_API_KEY=
PAYMENTS_SHOP_ID=
SBP_MERCHANT_ID=

# ──────────────────────────────────────────────────────────
# ОФД — обязателен (Q14 ✅ B2C+B2B микс), провайдер TBD под-блокер Q5
# ──────────────────────────────────────────────────────────
OFD_PROVIDER=mock
# OFD_PROVIDER=platform-ofd|taxcom|yandex-ofd|first-ofd
OFD_API_KEY=

# ──────────────────────────────────────────────────────────
# SMS (OTP + транзакционные)
# ──────────────────────────────────────────────────────────
SMS_PROVIDER=mock
# SMS_PROVIDER=smsaero|mts-exolve
SMS_API_KEY=
SMS_SENDER_ID=UniPrint

# ──────────────────────────────────────────────────────────
# Email
# ──────────────────────────────────────────────────────────
EMAIL_PROVIDER=mock
# EMAIL_PROVIDER=unisender-go|sendgrid
EMAIL_API_KEY=
EMAIL_FROM=noreply@uniprint.local

# ──────────────────────────────────────────────────────────
# WebPush (VAPID) — генерируется при первом запуске apps/notifications
# ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@uniprint.local

# ──────────────────────────────────────────────────────────
# Sentry (Q19 отложено, по умолчанию фаза 1.5+)
# ──────────────────────────────────────────────────────────
# SENTRY_DSN=

# ──────────────────────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────────────────────
WEBPUSH_ENABLED=true
SMS_ENABLED=true
EMAIL_ENABLED=true
# TELEGRAM_ENABLED — не нужен (Q7 ✅ исключено из продукта)

# ──────────────────────────────────────────────────────────
# Auth secrets
# ──────────────────────────────────────────────────────────
JWT_SECRET=replace-me
SESSION_SECRET=replace-me
